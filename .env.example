# Copy to .env and fill in the keys for whichever settings.model_provider you use.
# .env is gitignored — never commit real values.

GROQ_API_KEY=your_key
GOOGLE_API_KEY=your_key
ANTHROPIC_API_KEY=your_key

# The settings below are set automatically by docker-compose.yml when running
# containerized (docker compose run --rm app) and do not need to be set here
# for native/Mac execution:
#   MLFLOW_TRACKING_URI=http://mlflow:5000
#   OLLAMA_BASE_URL=http://host.docker.internal:11434
#   LOKI_URL=http://loki:3100/loki/api/v1/push
